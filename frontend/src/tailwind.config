/** @type {import('tailwindcss').Config} */
export default {
  content: ['./index.html', './src/**/*.{js,jsx}'],

  // "class" strategy means dark mode is toggled by adding the "dark" class
  // to the <html> element — we control this manually with a toggle button.
  darkMode: 'class',

  theme: {
    extend: {
      colors: {
        // --- BRAND COLORS ---
        // These stay the same in both light and dark mode.
        // Use these for buttons, links, highlights, and accents.
        brand: {
          navy:    '#0F2240',   // primary — headers, nav background in light mode
          amber:   '#F5A623',   // accent  — CTA buttons, highlights, active states
          amberHover: '#E09510', // slightly darker amber for button hover
        },

        // --- LIGHT MODE SURFACES ---
        // These are the backgrounds and card colors used in light mode.
        light: {
          bg:       '#F7F9FC',  // page background — off-white, easier on the eyes than pure white
          surface:  '#FFFFFF',  // card / panel background
          border:   '#E2E8F0',  // subtle dividers and borders
          muted:    '#64748B',  // secondary text — labels, captions
          text:     '#0F172A',  // primary text — headings and body copy
        },

        // --- DARK MODE SURFACES ---
        // Mirror of the light tokens above, used when "dark" class is on <html>.
        dark: {
          bg:       '#0A0F1E',  // deep near-black page background
          surface:  '#131C30',  // card / panel background — slightly lighter than bg
          border:   '#1E2D45',  // subtle dividers in dark mode
          muted:    '#94A3B8',  // secondary text in dark mode
          text:     '#E2E8F0',  // primary text in dark mode — soft white
        },
      },

      fontFamily: {
        display: ['Playfair Display', 'Georgia', 'serif'], // hero headlines only
        sans:    ['DM Sans', 'Inter', 'system-ui', 'sans-serif'], // everything else
      },
